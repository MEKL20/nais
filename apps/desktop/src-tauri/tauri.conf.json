{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NAIS",
  "version": "0.1.0",
  "identifier": "com.mekl.nais",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NAIS",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "publisher": "MEKL",
    "category": "Productivity",
    "shortDescription": "NAIS desktop assistant",
    "longDescription": "NAIS \u2014 Nano Assistant Intelligence System desktop client.",
    "resources": {
      "../../../characters": "characters"
    }
  }
}
