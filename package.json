{
  "name": "nais",
  "private": true,
  "version": "0.1.0",
  "description": "NAIS — Nano Assistant Intelligence System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @nais/desktop run dev",
    "build": "pnpm --filter @nais/desktop run build",
    "typecheck": "pnpm --filter @nais/desktop run typecheck && pnpm --filter @nais/character-schema run typecheck && pnpm --filter @nais/avatar-runtime run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke:desktop-avatar": "node scripts/smoke-desktop-avatar.mjs"
  },
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3"
  }
}
