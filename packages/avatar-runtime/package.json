{
  "name": "@nais/avatar-runtime",
  "version": "0.1.0",
  "description": "Avatar runtime contracts and placeholder adapters for NAIS Live2D and VRM renderers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix"
  },
  "devDependencies": {
    "@pixiv/three-vrm": "^3.5.3",
    "@types/three": "^0.170.0",
    "live2dcubismcore": "1.0.2",
    "pixi.js": "^7.4.3",
    "three": "^0.170.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "pixi-live2d-display": "0.5.0-beta"
  }
}
